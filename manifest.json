{
    "manifest_version": 3,
    "name": "YouTube Thumbnail Like Indicator",
    "version": "0.0.1",
    "description": "Shows whether a YouTube video was liked on its thumbnail.",
    "browser_specific_settings": {
        "gecko": {
            "id": "youtube-thumbnail-like-indicator@williamsteffens.dev",
            "data_collection_permissions": {
                "required": [
                    "none"
                ],
                "optional": []
            }
        }
    },
    "permissions": [
        "storage",
        "identity",
        "tabs"
    ],
    "host_permissions": [
        "https://www.youtube.com/*",
        "https://www.googleapis.com/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}